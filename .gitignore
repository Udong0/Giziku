# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# === Local machine config — JANGAN di-commit ===
# Path SDK per-mesin (akan beda di tiap laptop anggota tim)
/android/local.properties
/ios/Flutter/flutter_export_environment.sh

# === Secrets / API keys ===
.env
.env.*
!.env.example
# Kalau pakai launch.json untuk simpan GEMINI_API_KEY, jangan di-commit
.vscode/launch.json
.vscode/settings.json

# === Firebase config (tambah saat tim integrasi Firebase) ===
# Boleh di-commit kalau Firestore rules sudah ketat & repo private, tapi
# default-nya kita ignore supaya tidak ada API key bocor di repo publik.
**/android/app/google-services.json
**/ios/Runner/GoogleService-Info.plist
**/macos/Runner/GoogleService-Info.plist
lib/firebase_options.dart

# === Android signing (release build) ===
/android/key.properties
**/*.keystore
**/*.jks

# === Generated code (kalau pakai build_runner / freezed nanti) ===
*.g.dart
*.freezed.dart
*.mocks.dart

# === Misc Flutter ===
.flutter-plugins
**/windows/flutter/ephemeral/
**/macos/Flutter/ephemeral/
**/linux/flutter/ephemeral/

# === Claude Code config===
.claude/

